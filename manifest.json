{
  "manifest_version": 3,
  "name": "Fragment Flow: Multithreaded Downloader",
  "version": "0.1.0",
  "description": "An IDM-like manager using parallel processing to reduce system lag.",
  "permissions": [
    "downloads",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "style-src 'self' https://cdn.jsdelivr.net; script-src 'self' https://cdn.jsdelivr.net;"
  },
  "minimum_chrome_version": "109"
}